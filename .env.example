# SendGrid Newsletter Signup
# Get your API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# SendGrid Marketing Contact List ID
# Find this under Marketing > Contacts > your list > Settings
# Leave empty to add contacts without assigning to a specific list
SENDGRID_LIST_ID=your_list_id_here
